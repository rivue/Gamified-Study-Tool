def run_upgrades():
    if os.getenv('RUN_SEEDING', 'False') == 'True':
        upgrade_user_exp()
        upgrade_library_socials()
        upgrade_lib_imgs()
        upgrade_lib_guide()
        upgrade_lib_times()
