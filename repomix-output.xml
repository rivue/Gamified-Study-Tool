export default {
  data() {
    return {
      page: 0,
      rating: 0,
      feedback: "",
      showFeedback: false,
      isSubmitted: false,
      suggestions: [],
      exploreLoading: false,
      loading: false,
      showLeaderBoard: false,
    };
  },
  components: {
    CyclingContentButton,
