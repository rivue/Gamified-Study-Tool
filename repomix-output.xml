        line_graph_data = get_line_graph_data(current_user.id)
        stats = get_stats(current_user.id)

        data = {
            "lineGraph": line_graph_data,
            "totalCompleted": stats['totalCompleted'],
            "totalLessons": stats['totalLessons'],
