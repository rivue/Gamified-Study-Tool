    },
    {
      id: 5,
      label: 'Achievement 1',
      icon: TrophyIcon,
      unlocked: false,
      current: false
    },
    {
      id: 6,
      label: 'Advanced Topics',
      icon: AcademicCapIcon,
      unlocked: false,
      current: false
    },
    {
      id: 7,
      label: 'Lab Practice',
