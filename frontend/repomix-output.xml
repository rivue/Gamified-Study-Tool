  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.5);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes gold-flash {
  0% {
    fill: green;
  }
  50% {
    fill: gold;
  }
  100% {
    fill: green;
  }
}

.gold-color {
  fill: gold;
}
