:root {
    /* Primary Brand Colors - Teal */
    --color-primary: #1A8B7F;
    --color-primary-light: #33B2A5;
    --color-primary-lighter: #66C5BC;
    --color-primary-dark: #156F66;
    --color-primary-darker: #10534C;
  
    --background-color: #0a1f1f;
    --background-color-rgb: 10, 31, 31;
    --background-haze: rgba(10, 31, 31, 0.94);
    --background-button-haze: rgba(10, 31, 31, 0.73);
    
    /* Gradient Backgrounds for Cards/Sections */
    --background-color-1t: rgba(20, 140, 140, 0.26);  /* Teal transparency */
    --background-color-2t: rgba(52, 185, 185, 0.26);  /* Lighter teal transparency */
    
    /* Primary Interactive Elements */
    --element-color-1: #0d9488;  /* Deep teal */
    --element-color-2: #14b8a6;  /* Bright teal */
    
    /* Highlights and Accents */
    --highlight-color: #99f6e4;  /* Soft teal */
    --text-color: #f8fafc;      /* Crisp white with slight blue tint */
    --text-color-rgb: 248, 250, 252;
    
    /* Special Colors */
    --gold-color: rgba(255, 216, 4, 0.8);  /* Slightly transparent gold */
    
    /* Utility Colors */
    --light-text: #f8fafc;
    --light-highlight: #99f6e4;
    --black-back: #0a1f1f;
    
    /* New Accent Colors */
    --success-color: #10b981;    /* Emerald green */
    --feature-gradient: linear-gradient(135deg, rgba(13, 148, 136, 0.1), rgba(20, 184, 166, 0.1));
    --button-gradient: linear-gradient(135deg, var(--element-color-1), var(--element-color-2));
}

.light-theme {
    --background-color: #f0f8ff;
    --background-color-rgb: 240, 248, 255;
    --background-haze: #f0f8ef;
    --background-button-haze: #f0f8ffba;
    --background-color-1t: #2a14ff42;
    --background-color-2t: #dad1ff42;
    --element-color-1: #9a8bff;
    --element-color-2: #6a4afa;
    --highlight-color: #250849;
    --text-color: #0e0c14;
    --text-color-rgb: 14, 12, 20;
    --gold-color: #ffd804cc;

    --light-text: #f0f8ff;
    --light-highlight: #cea8fc;
    --black-back: #0e0c14;
}
