    getStats() {
      if (this.streak === null || this.exp === null) {
        // console.log("nulls")
        this.fetchStatsFromBackend();
      }
    //   console.log(this.exp, this.ste)
      return {
        streak: this.streak,
        exp: this.exp,
      };
    },
    resetStats(){
      this.streak = null;
      this.exp = null;
    }
  },
});
