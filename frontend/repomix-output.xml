    AcademicCapIcon,
    BeakerIcon,
    ChevronLeftIcon,
    ChevronRightIcon,
    PuzzlePieceIcon,
    RocketLaunchIcon,
    SparklesIcon
  } from '@heroicons/vue/24/solid'
  
  // Node data
  const nodes = ref([
    {
      id: 1,
      label: 'Start Here',
      icon: StarIcon,
      unlocked: true,
      current: true
